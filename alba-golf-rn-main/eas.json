{
  "cli": {
    "version": ">= 16.12.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "development-tf": {
      "distribution": "store",
      "environment": "development",
      "channel": "development",
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "preview": {
      "distribution": "store",
      "environment": "preview",
      "channel": "preview",
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      }   
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      }   
    }
  },
  "submit": {
    "development-tf": {
      "ios": {}
    },
    "production": {
      "android": {
        "serviceAccountKeyPath": "./service-account-key.json",
        "track": "production"
      }
    },
    "preview": {
      "android": {
        "track": "internal"
      }
    }
  }
}
